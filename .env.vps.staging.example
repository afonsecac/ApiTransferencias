# ===========================================
# VPS STAGING - Copiar a .env.vps en el servidor staging
# ===========================================

# --- Infraestructura ---
DOMAIN=staging-api.comremit.com
ACME_EMAIL=soporte@comremit.com
TRAEFIK_LOG_LEVEL=WARN

# Allowlist de IP (CIDR, separadas por coma) para los paneles administrativos
# expuestos por Traefik: dashboard de Traefik, RabbitMQ management y mailcatcher.
# Sin este valor solo se permite loopback (acceso externo bloqueado).
# Ej: ADMIN_IP_ALLOWLIST=203.0.113.10/32,10.8.0.0/24
ADMIN_IP_ALLOWLIST=127.0.0.1/32

# Proxies de confianza para resolver la IP real del cliente (X-Forwarded-For).
# 'private_ranges' cubre la red interna de Docker donde vive Traefik.
TRUSTED_PROXIES=private_ranges

# Traefik dashboard auth (generar con: htpasswd -nB admin)
# Formato: usuario:hash (escapar $ con $$)
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$CHANGE_ME

# --- Aplicacion ---
# No usar APP_ENV=dev / APP_DEBUG=1 en un entorno accesible desde Internet: el
# modo debug filtra trazas de excepción, variables de entorno y detalles internos.
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# --- Base de datos ---
POSTGRES_DB=api_transferencias_staging
POSTGRES_USER=api_staging
POSTGRES_PASSWORD=CHANGE_ME_STAGING_PASSWORD

# --- RabbitMQ ---
RABBITMQ_USER=api_rabbitmq
RABBITMQ_PASSWORD=CHANGE_ME_STAGING_PASSWORD
MESSENGER_TRANSPORT_VHOST=client-vh1
MESSENGER_TRANSPORT_FAILURE=doctrine://default?queue_name=failed
# IMPORTANTE: si el password tiene caracteres especiales (+ / = @ : # ?)
# deben codificarse como %XX en el DSN. Ej: + → %2B, / → %2F, = → %3D, @ → %40
MESSENGER_TRANSPORT_DSN=amqp://api_rabbitmq:URL_ENCODED_PASSWORD@rabbitmq:5672/%2f/

# --- SMTP (mailcatcher en staging - no envia correo real) ---
MAILER_DSN=smtp://mailcatcher:1025

# --- JWT ---
JWT_MEMORY_KEY=staging_jwt_memory_key
JWT_PHRASE_KEY=staging_jwt_phrase_key
JWT_TIMEOUT=30

# --- CORS ---
# No usar '.*' con allow_credentials: true (config/packages/nelmio_cors.yaml):
# equivale a reflejar cualquier origen con credenciales y anula la protección CORS.
# Acotar a los dominios concretos del frontend de staging.
CORS_ALLOW_ORIGIN='^https?://(staging-api\.comremit\.com|dashboard-staging\.comremit\.com)(:[0-9]+)?$$'
CORS_DASHBOARD_ORIGIN='^https://dashboard-staging\.comremit\.com$$'

# --- Otros ---
MICROSOFT_URL=https://login.microsoftonline.com
APP_TEST_PHONE=5350499650
APP_MAILER_FROM=soporte@comremit.com
APP_ERROR_RECIPIENTS=afonsecacardosa@gmail.com
COMREMIT_DASHBOARD_URL=https://dashboard-staging.comremit.com
SENDMUNDO_DASHBOARD_URL=https://dashboard-staging.sendmundo.com
# --- SysConfig encryption ---
# Clave AES para cifrar valores sensibles en sys_config (ej: api.communications.key)
# Generar con: openssl rand -hex 32
SYS_CONFIG_ENCRYPTION_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32
