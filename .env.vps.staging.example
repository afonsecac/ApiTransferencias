# ===========================================
# VPS STAGING - Copiar a .env.vps en el servidor staging
# ===========================================

# --- Infraestructura ---
DOMAIN=staging-api.sendmundo.com
ACME_EMAIL=soporte@comremit.com
TRAEFIK_LOG_LEVEL=DEBUG

# Traefik dashboard auth (generar con: htpasswd -nB admin)
# Formato: usuario:hash (escapar $ con $$)
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$CHANGE_ME

# --- Aplicacion ---
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# --- Base de datos ---
POSTGRES_DB=api_transferencias_staging
POSTGRES_USER=api_staging
POSTGRES_PASSWORD=CHANGE_ME_STAGING_PASSWORD

# --- RabbitMQ ---
RABBITMQ_USER=api_rabbitmq
RABBITMQ_PASSWORD=CHANGE_ME_STAGING_PASSWORD
MESSENGER_TRANSPORT_VHOST=client-vh1
MESSENGER_TRANSPORT_FAILURE=doctrine://default?queue_name=failed
# IMPORTANTE: si el password tiene caracteres especiales (+ / = @ : # ?)
# deben codificarse como %XX en el DSN. Ej: + → %2B, / → %2F, = → %3D, @ → %40
MESSENGER_TRANSPORT_DSN=amqp://api_rabbitmq:URL_ENCODED_PASSWORD@rabbitmq:5672/%2f/

# --- SMTP (mailcatcher en staging - no envia correo real) ---
MAILER_DSN=smtp://mailcatcher:1025

# --- JWT ---
JWT_MEMORY_KEY=staging_jwt_memory_key
JWT_PHRASE_KEY=staging_jwt_phrase_key
JWT_TIMEOUT=30

# --- CORS ---
CORS_ALLOW_ORIGIN='^https?://.*$$'
CORS_DASHBOARD_ORIGIN='^https://dashboard-staging\.comremit\.com$$'

# --- Otros ---
MICROSOFT_URL=https://login.microsoftonline.com
APP_TEST_PHONE=5350499650
APP_MAILER_FROM=soporte@comremit.com
APP_ERROR_RECIPIENTS=afonsecacardosa@gmail.com
