{% extends 'emails/_base.html.twig' %}

{% block title %}Cambio de contrase&ntilde;a{% endblock %}

{% block logo %}
    <img src="https://www.sendmundo.com/img/header/comremit-logo.svg" alt="SendMundo"
         width="200" height="60" style="display: block; margin: 0 auto; max-width: 200px; height: auto; border: 0;"/>
{% endblock %}

{% block accent_color %}#d9000d{% endblock %}
{% block footer_bg_color %}#d9000d{% endblock %}

{% block content %}
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <!-- Title -->
        <tr>
            <td align="center" style="font-size: 24px; font-weight: bold; color: #d9000d; padding-bottom: 20px; font-family: Arial, Helvetica, sans-serif;">
                Cambio de contrase&ntilde;a / Change password
            </td>
        </tr>
        <!-- Description ES -->
        <tr>
            <td align="center" style="font-size: 14px; color: #333333; line-height: 22px; padding-bottom: 8px; font-family: Arial, Helvetica, sans-serif;">
                Hemos recibido una solicitud de cambio de contrase&ntilde;a. El c&oacute;digo de validaci&oacute;n de su cuenta es:
            </td>
        </tr>
        <!-- Description EN -->
        <tr>
            <td align="center" style="font-size: 14px; color: #888888; line-height: 22px; padding-bottom: 25px; font-family: Arial, Helvetica, sans-serif;">
                We have received a request to change your password. The validation code for your account is:
            </td>
        </tr>
        <!-- Code box -->
        <tr>
            <td align="center" style="padding-bottom: 30px;">
                <table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin: 0 auto;">
                    <tr>
                        <td style="border: 2px solid #d9000d; padding: 14px 36px; font-size: 30px; font-weight: bold; letter-spacing: 8px; color: #d9000d; text-transform: uppercase; text-align: center; font-family: Arial, Helvetica, sans-serif;">
                            {{ code }}
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
        <!-- Disclaimer ES -->
        <tr>
            <td align="center" style="font-size: 13px; color: #666666; line-height: 20px; padding-bottom: 5px; font-family: Arial, Helvetica, sans-serif;">
                Si no ha sido usted el que ha realizado la solicitud, no es necesario que realice ninguna acci&oacute;n.
            </td>
        </tr>
        <!-- Disclaimer EN -->
        <tr>
            <td align="center" style="font-size: 13px; color: #999999; line-height: 20px; font-family: Arial, Helvetica, sans-serif;">
                If you did not make the change request, you do not need to take any action.
            </td>
        </tr>
    </table>
{% endblock %}

{% block footer %}
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
            <td align="center" style="color: #ffffff; font-size: 14px; font-weight: bold; padding-bottom: 8px; font-family: Arial, Helvetica, sans-serif;">
                SendMundo Communications and Finance Technologies SL
            </td>
        </tr>
        <tr>
            <td align="center" style="color: rgba(255,255,255,0.85); font-size: 12px; line-height: 18px; padding-bottom: 5px; font-family: Arial, Helvetica, sans-serif;">
                Pasaje del Carme, 24, Sant Cugat del Vall&eacute;s, 08173. Barcelona, Espa&ntilde;a
            </td>
        </tr>
        <tr>
            <td align="center" style="color: rgba(255,255,255,0.85); font-size: 12px; padding-bottom: 8px; font-family: Arial, Helvetica, sans-serif;">
                CIF: B42981191
            </td>
        </tr>
        <tr>
            <td align="center">
                <a href="https://dashboard.sendmundo.com" style="color: #ffffff; font-size: 12px; text-decoration: underline; font-family: Arial, Helvetica, sans-serif;">
                    dashboard.sendmundo.com
                </a>
            </td>
        </tr>
    </table>
{% endblock %}
