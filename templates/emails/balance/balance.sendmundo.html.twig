{% extends 'emails/_base.html.twig' %}

{% block title %}Balance Alert{% endblock %}

{% block logo %}
    <img src="https://www.sendmundo.com/img/header/comremit-logo.svg" alt="SendMundo"
         width="200" height="60" style="display: block; margin: 0 auto; max-width: 200px; height: auto; border: 0;"/>
{% endblock %}

{% block accent_color %}#d9000d{% endblock %}
{% block footer_bg_color %}#d9000d{% endblock %}

{% block content %}
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <!-- Title ES -->
        <tr>
            <td align="center" style="font-size: 22px; font-weight: bold; color: #d9000d; padding-bottom: 5px; font-family: Arial, Helvetica, sans-serif;">
                &iexcl;SALDO EN ESTADO {{ status_es }}!
            </td>
        </tr>
        <!-- Title EN -->
        <tr>
            <td align="center" style="font-size: 16px; font-weight: bold; color: #888888; padding-bottom: 25px; font-family: Arial, Helvetica, sans-serif;">
                {{ status_en }} STATE BALANCE!
            </td>
        </tr>
        <!-- Body ES -->
        <tr>
            <td style="font-size: 14px; color: #333333; line-height: 22px; padding-bottom: 8px; font-family: Arial, Helvetica, sans-serif;">
                Estimado cliente {{ name }}, el motivo de este correo electr&oacute;nico es para ponerlo al tanto del estado de su saldo en nuestra plataforma. Sugerimos realizar un dep&oacute;sito para que sus operaciones no se vean afectadas.
            </td>
        </tr>
        <!-- Body EN -->
        <tr>
            <td style="font-size: 14px; color: #888888; line-height: 22px; padding-bottom: 20px; font-family: Arial, Helvetica, sans-serif;">
                Dear customer {{ name }}, the purpose of this email is to inform you about the status of your balance on our platform. We suggest making a deposit so that your operations are not affected.
            </td>
        </tr>
        <!-- Platform ES -->
        <tr>
            <td style="font-size: 14px; color: #333333; line-height: 22px; padding-bottom: 8px; font-family: Arial, Helvetica, sans-serif;">
                La plataforma que se ver&aacute; afectada para realizar las operaciones ser&aacute; la de {{ platform }}.
            </td>
        </tr>
        <!-- Platform EN -->
        <tr>
            <td style="font-size: 14px; color: #888888; line-height: 22px; padding-bottom: 25px; font-family: Arial, Helvetica, sans-serif;">
                The platform that will be affected to carry out the operations will be {{ platform }}.
            </td>
        </tr>
        <!-- Data Table -->
        <tr>
            <td align="center" style="padding-bottom: 25px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width: 420px; margin: 0 auto; border: 1px solid #dddddd; border-collapse: collapse;">
                    <!-- Row: Balance -->
                    <tr>
                        <td style="background-color: #f8f8f8; padding: 12px 15px; font-size: 13px; font-weight: bold; color: #d9000d; border-bottom: 1px solid #dddddd; width: 50%; font-family: Arial, Helvetica, sans-serif;">
                            Saldo Actual / Current Amount
                        </td>
                        <td style="background-color: #f8f8f8; padding: 12px 15px; font-size: 14px; color: #333333; border-bottom: 1px solid #dddddd; font-family: Arial, Helvetica, sans-serif;">
                            {{ balance | round(2, 'floor') }}
                        </td>
                    </tr>
                    <!-- Row: Currency -->
                    <tr>
                        <td style="padding: 12px 15px; font-size: 13px; font-weight: bold; color: #d9000d; border-bottom: 1px solid #dddddd; font-family: Arial, Helvetica, sans-serif;">
                            Moneda / Currency
                        </td>
                        <td style="padding: 12px 15px; font-size: 14px; color: #333333; border-bottom: 1px solid #dddddd; font-family: Arial, Helvetica, sans-serif;">
                            {{ currency }}
                        </td>
                    </tr>
                    <!-- Row: Date -->
                    <tr>
                        <td style="background-color: #f8f8f8; padding: 12px 15px; font-size: 13px; font-weight: bold; color: #d9000d; font-family: Arial, Helvetica, sans-serif;">
                            Fecha / Date
                        </td>
                        <td style="background-color: #f8f8f8; padding: 12px 15px; font-size: 14px; color: #333333; font-family: Arial, Helvetica, sans-serif;">
                            {{ 'now' | date('d/m/Y') }}
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
        <!-- Divider -->
        <tr>
            <td style="padding-bottom: 20px;">
                <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                    <tr>
                        <td style="border-top: 1px solid #dddddd; font-size: 1px; line-height: 1px;">&nbsp;</td>
                    </tr>
                </table>
            </td>
        </tr>
        <!-- Thank you -->
        <tr>
            <td align="center" style="font-size: 14px; font-weight: bold; color: #333333; padding-bottom: 10px; font-family: Arial, Helvetica, sans-serif;">
                &iexcl;Muchas gracias por elegirnos!
            </td>
        </tr>
        <!-- Contact label -->
        <tr>
            <td align="center" style="font-size: 13px; color: #666666; padding-bottom: 5px; font-family: Arial, Helvetica, sans-serif;">
                Cont&aacute;ctenos a / Contact us at
            </td>
        </tr>
        <!-- Contact email -->
        <tr>
            <td align="center" style="padding-bottom: 5px;">
                <a href="mailto:{{ mail }}" style="color: #d9000d; font-size: 14px; font-weight: bold; text-decoration: underline; font-family: Arial, Helvetica, sans-serif;">
                    {{ mail }}
                </a>
            </td>
        </tr>
    </table>
{% endblock %}

{% block footer %}
    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
            <td align="center" style="color: #ffffff; font-size: 14px; font-weight: bold; padding-bottom: 8px; font-family: Arial, Helvetica, sans-serif;">
                SendMundo Communications and Finance Technologies SL
            </td>
        </tr>
        <tr>
            <td align="center" style="color: rgba(255,255,255,0.85); font-size: 12px; line-height: 18px; padding-bottom: 5px; font-family: Arial, Helvetica, sans-serif;">
                Pasaje del Carme, 24, Sant Cugat del Vall&eacute;s, 08173. Barcelona, Espa&ntilde;a
            </td>
        </tr>
        <tr>
            <td align="center" style="color: rgba(255,255,255,0.85); font-size: 12px; padding-bottom: 8px; font-family: Arial, Helvetica, sans-serif;">
                CIF: B42981191
            </td>
        </tr>
        <tr>
            <td align="center">
                <a href="https://dashboard.sendmundo.com" style="color: #ffffff; font-size: 12px; text-decoration: underline; font-family: Arial, Helvetica, sans-serif;">
                    dashboard.sendmundo.com
                </a>
            </td>
        </tr>
    </table>
{% endblock %}
