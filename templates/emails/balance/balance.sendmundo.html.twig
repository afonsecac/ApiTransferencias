{% extends 'emails/_base.html.twig' %}

{% set alert_bg = status_en == 'CRITICAL' ? '#D9000D' : '#D97706' %}

{% block title %}Alerta de saldo — SendMundo{% endblock %}

{% block preheader %}&#9888; Saldo {{ status_es }} en {{ platform }} — {{ balance|round(2, 'floor') }} {{ currency }}{% endblock %}

{% block brand_header %}
<span style="font-size:20px;font-weight:bold;color:#ffffff;font-family:Arial,Helvetica,sans-serif;letter-spacing:0.5px;">
    SendMundo
</span>
{% endblock %}

{% block logo_area %}
<tr>
    <td align="center" style="background-color:#ffffff;padding:20px 40px 16px 40px;border-bottom:1px solid #ebebeb;">
        <img src="https://www.sendmundo.com/img/header/comremit-logo.svg"
             alt="SendMundo" width="160" style="display:block;margin:0 auto;max-width:160px;height:auto;border:0;"/>
    </td>
</tr>
{% endblock %}

{% block banner %}
<tr>
    <td align="center" style="background-color:{{ alert_bg }};padding:28px 40px 24px 40px;">
        <p style="margin:0 0 6px 0;font-size:24px;font-weight:bold;color:#ffffff;
                  font-family:Arial,Helvetica,sans-serif;line-height:1.2;">
            Alerta de Saldo
        </p>
        <p style="margin:0;font-size:14px;color:rgba(255,255,255,0.85);font-family:Arial,Helvetica,sans-serif;">
            &#9888;&#xFE0E;&nbsp; Saldo en estado {{ status_es }} &bull; {{ status_en }} Balance
        </p>
    </td>
</tr>
{% endblock %}

{% block content %}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">

    <!-- GREETING + MESSAGE ES -->
    <tr>
        <td style="font-size:14px;color:#1a1a1a;line-height:24px;padding-bottom:6px;font-family:Arial,Helvetica,sans-serif;">
            Estimado cliente <strong>{{ name }}</strong>,<br/>
            el saldo de su cuenta en la plataforma <strong>{{ platform }}</strong> ha alcanzado un nivel
            <strong style="color:{{ alert_bg }};">{{ status_es|lower }}</strong>.
            Le recomendamos realizar un dep&oacute;sito para evitar interrupciones en sus operaciones.
        </td>
    </tr>

    <!-- MESSAGE EN -->
    <tr>
        <td style="font-size:13px;color:#888888;line-height:22px;padding-bottom:28px;font-family:Arial,Helvetica,sans-serif;">
            Dear <strong>{{ name }}</strong>, your account balance on the <strong>{{ platform }}</strong> platform
            has reached a <strong>{{ status_en|lower }}</strong> level.
            We recommend making a deposit to avoid service interruptions.
        </td>
    </tr>

    <!-- DATA CARD -->
    <tr>
        <td style="padding-bottom:28px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0"
                   style="border:1px solid #e0e0e0;border-collapse:collapse;border-radius:4px;">

                <!-- Amount row -->
                <tr>
                    <td style="background-color:#fafafa;padding:14px 18px;font-size:12px;font-weight:bold;
                                color:#666666;text-transform:uppercase;letter-spacing:0.5px;
                                border-bottom:1px solid #e0e0e0;width:45%;
                                font-family:Arial,Helvetica,sans-serif;">
                        Saldo Actual<br/>
                        <span style="font-weight:normal;text-transform:none;letter-spacing:0;">Current Balance</span>
                    </td>
                    <td style="background-color:#fafafa;padding:14px 18px;font-size:22px;font-weight:bold;
                                color:{{ alert_bg }};border-bottom:1px solid #e0e0e0;
                                font-family:Arial,Helvetica,sans-serif;">
                        {{ balance|number_format(2, '.', ',') }}&nbsp;<span style="font-size:14px;color:#888888;">{{ currency }}</span>
                    </td>
                </tr>

                <!-- Platform row -->
                <tr>
                    <td style="padding:12px 18px;font-size:12px;font-weight:bold;color:#666666;
                                text-transform:uppercase;letter-spacing:0.5px;
                                border-bottom:1px solid #e0e0e0;
                                font-family:Arial,Helvetica,sans-serif;">
                        Plataforma<br/>
                        <span style="font-weight:normal;text-transform:none;letter-spacing:0;">Platform</span>
                    </td>
                    <td style="padding:12px 18px;font-size:14px;color:#1a1a1a;
                                border-bottom:1px solid #e0e0e0;
                                font-family:Arial,Helvetica,sans-serif;">
                        {{ platform }}
                    </td>
                </tr>

                <!-- Date row -->
                <tr>
                    <td style="background-color:#fafafa;padding:12px 18px;font-size:12px;font-weight:bold;
                                color:#666666;text-transform:uppercase;letter-spacing:0.5px;
                                font-family:Arial,Helvetica,sans-serif;">
                        Fecha / Date
                    </td>
                    <td style="background-color:#fafafa;padding:12px 18px;font-size:14px;color:#1a1a1a;
                                font-family:Arial,Helvetica,sans-serif;">
                        {{ 'now'|date('d/m/Y H:i') }} (UTC)
                    </td>
                </tr>

            </table>
        </td>
    </tr>

    <!-- SEPARATOR -->
    <tr>
        <td style="padding-bottom:20px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
                <tr><td style="border-top:1px solid #e0e0e0;font-size:1px;line-height:1px;">&nbsp;</td></tr>
            </table>
        </td>
    </tr>

    <!-- CONTACT -->
    <tr>
        <td align="center" style="font-size:13px;color:#666666;padding-bottom:6px;font-family:Arial,Helvetica,sans-serif;">
            &iexcl;Gracias por confiar en nosotros! &mdash; Thank you for trusting us!
        </td>
    </tr>
    <tr>
        <td align="center" style="font-size:13px;color:#888888;padding-bottom:4px;font-family:Arial,Helvetica,sans-serif;">
            Cont&aacute;ctenos / Contact us
        </td>
    </tr>
    <tr>
        <td align="center">
            <a href="mailto:{{ mail }}"
               style="color:#D9000D;font-size:14px;font-weight:bold;text-decoration:none;font-family:Arial,Helvetica,sans-serif;">
                {{ mail }}
            </a>
        </td>
    </tr>

</table>
{% endblock %}

{% block footer %}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
    <tr>
        <td align="center" style="color:#ffffff;font-size:13px;font-weight:bold;padding-bottom:4px;font-family:Arial,Helvetica,sans-serif;">
            SendMundo Communications and Finance Technologies SL
        </td>
    </tr>
    <tr>
        <td align="center" style="color:rgba(255,255,255,0.6);font-size:11px;line-height:18px;padding-bottom:10px;font-family:Arial,Helvetica,sans-serif;">
            Pasaje del Carme, 24 &mdash; Sant Cugat del Vall&eacute;s, 08173 &mdash; Barcelona, Espa&ntilde;a &mdash; CIF: B42981191
        </td>
    </tr>
    <tr>
        <td align="center" style="padding-bottom:10px;">
            <a href="https://dashboard.sendmundo.com"
               style="color:rgba(255,255,255,0.8);font-size:12px;text-decoration:underline;font-family:Arial,Helvetica,sans-serif;">
                dashboard.sendmundo.com
            </a>
        </td>
    </tr>
    <tr>
        <td align="center" style="border-top:1px solid rgba(255,255,255,0.12);padding-top:12px;
                                   font-size:11px;color:rgba(255,255,255,0.45);font-family:Arial,Helvetica,sans-serif;">
            Este es un mensaje autom&aacute;tico &mdash; por favor no respondas a este correo.
        </td>
    </tr>
</table>
{% endblock %}
