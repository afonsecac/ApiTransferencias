# ===========================================
# VPS PRODUCCION - Copiar a .env.vps en el servidor de produccion
# ===========================================

# --- Infraestructura ---
DOMAIN=api.prod.comremit.com
DOMAIN_ALIAS=api-tx.sendmundo.com
ACME_EMAIL=soporte@comremit.com
TRAEFIK_LOG_LEVEL=WARN

# Traefik dashboard auth (generar con: htpasswd -nB admin)
# Formato: usuario:hash (escapar $ con $$)
TRAEFIK_DASHBOARD_AUTH=admin:$$2y$$05$$CHANGE_ME

# --- Aplicacion ---
APP_ENV=prod
APP_DEBUG=0
APP_SECRET=CHANGE_ME_GENERATE_WITH_openssl_rand_hex_32

# --- Base de datos ---
POSTGRES_DB=api_transferencias
POSTGRES_USER=api_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_32_CHARS

# --- RabbitMQ ---
RABBITMQ_USER=api_rabbitmq
RABBITMQ_PASSWORD=CHANGE_ME_STRONG_PASSWORD_MIN_32_CHARS
MESSENGER_TRANSPORT_VHOST=client-vh1
MESSENGER_TRANSPORT_FAILURE=doctrine://default?queue_name=failed
# IMPORTANTE: si el password tiene caracteres especiales (+ / = @ : # ?)
# deben codificarse como %XX en el DSN. Ej: + → %2B, / → %2F, = → %3D, @ → %40
# El password de RABBITMQ_PASSWORD se usa tal cual por RabbitMQ; aqui va el DSN con el password codificado.
MESSENGER_TRANSPORT_DSN=amqp://api_rabbitmq:URL_ENCODED_PASSWORD@rabbitmq:5672/%2f/

# --- SMTP (correo real en produccion) ---
MAILER_DSN=smtps://user:password@smtps.aruba.it:465

# --- JWT ---
JWT_MEMORY_KEY=CHANGE_ME_STRONG_KEY
JWT_PHRASE_KEY=CHANGE_ME_STRONG_KEY
JWT_TIMEOUT=30

# --- CORS (ambos dominios durante la transicion) ---
CORS_ALLOW_ORIGIN='^https?://(api\.prod\.comremit\.com|api-tx\.sendmundo\.com)(:[0-9]+)?$$'
CORS_DASHBOARD_ORIGIN='^https://dashboard\.comremit\.com$$'

# --- Otros ---
MICROSOFT_URL=https://login.microsoftonline.com
APP_TEST_PHONE=5350499650
APP_MAILER_FROM=soporte@comremit.com
